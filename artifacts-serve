#!/usr/bin/env bash
#
# artifacts-serve
# Standalone script to start server and open Firefox private window
#
# Usage: ./artifacts-serve [port]
#

set -e

# Default configuration
PORT="${1:-8080}"
HOST="localhost"
DIR="/home/user/work/code/artifacts"
URL="http://${HOST}:${PORT}/app-hub-v11/index.html"
PID_FILE="${DIR}/.artifacts-server.pid"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if already running
if [[ -f "$PID_FILE" ]]; then
    OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
    if kill -0 "$OLD_PID" 2>/dev/null; then
        echo -e "${YELLOW}⚠ Server already running (PID: $OLD_PID)${NC}"
        echo -e "${CYAN}  Opening Firefox to existing server...${NC}"

        if command -v firefox &>/dev/null; then
            firefox --private-window "$URL" &>/dev/null &
        elif command -v firefox-esr &>/dev/null; then
            firefox-esr --private-window "$URL" &>/dev/null &
        fi
        exit 0
    else
        rm -f "$PID_FILE"
    fi
fi

# Check directory
if [[ ! -d "$DIR" ]]; then
    echo -e "${RED}✗ Error: Directory not found: $DIR${NC}"
    exit 1
fi

# Start server
echo -e "${CYAN}🚀 Starting Artifacts server...${NC}"
cd "$DIR"

python3 -m http.server "$PORT" > /dev/null 2>&1 &
SERVER_PID=$!

echo $SERVER_PID > "$PID_FILE"

# Wait for server to start
sleep 0.8

# Verify
if ! kill -0 $SERVER_PID 2>/dev/null; then
    echo -e "${RED}✗ Failed to start server${NC}"
    rm -f "$PID_FILE"
    exit 1
fi

echo -e "${GREEN}✓ Server started${NC}"
echo -e "${CYAN}  Port: ${PORT}${NC}"
echo -e "${CYAN}  PID:  ${SERVER_PID}${NC}"
echo -e "${CYAN}  URL:  ${GREEN}${URL}${NC}"

# Open Firefox
echo -e "${CYAN}🌐 Opening Firefox Private Window...${NC}"

if command -v firefox &>/dev/null; then
    firefox --private-window "$URL" &>/dev/null &
elif command -v firefox-esr &>/dev/null; then
    firefox-esr --private-window "$URL" &>/dev/null &
else
    echo -e "${YELLOW}⚠ Firefox not found. Open manually:${NC}"
    echo -e "  ${URL}"
    exit 0
fi

echo -e "${GREEN}✓ Done! NEXUS App Hub v11 loading...${NC}"
echo ""
echo -e "${CYAN}Press Ctrl+C to stop the server${NC}"

# Handle graceful shutdown
trap cleanup INT TERM

cleanup() {
    echo ""
    echo -e "${CYAN}🛑 Stopping server...${NC}"
    kill $SERVER_PID 2>/dev/null
    rm -f "$PID_FILE"
    echo -e "${GREEN}✓ Server stopped${NC}"
    exit 0
}

# Keep script running
wait $SERVER_PID
