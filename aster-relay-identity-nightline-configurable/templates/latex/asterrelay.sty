\definecolor{arObs}{HTML}{090b16}
\definecolor{arNight}{HTML}{10142a}
\definecolor{arIndigo}{HTML}{1b2455}
\definecolor{arRelay}{HTML}{6e58ff}
\definecolor{arViolet}{HTML}{9b7dff}
\definecolor{arMist}{HTML}{dfe4ff}
\definecolor{arIce}{HTML}{f5f7ff}
\definecolor{arLine}{HTML}{2f3b78}
