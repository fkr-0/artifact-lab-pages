#!/usr/bin/env bash
#
# artifacts-package - Create distributable tgz package from app-hub-v11 manifest
#
# Usage: ./artifacts-package [output-dir]
#

set -euo pipefail

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

ARTIFACTS_DIR="${ARTIFACTS_DIR:-/home/user/work/code/artifacts}"
PACKAGE_NAME="artifacts-collection"
VERSION=$(date +%Y.%m.%d)
OUTPUT_DIR="${1:-$ARTIFACTS_DIR}"
STAGE_ROOT="$(mktemp -d)"
STAGE="$STAGE_ROOT/$PACKAGE_NAME"
trap 'rm -rf "$STAGE_ROOT"' EXIT

echo -e "${CYAN}📦 Artifacts Collection - Manifest Packaging${NC}"
echo ""
echo -e "${CYAN}Materializing app-hub-v11 manifest...${NC}"
cd "$ARTIFACTS_DIR"
node app-hub-v11/server/artifact-build.mjs --out "$STAGE"

cat > "$STAGE/VERSION" <<EOF_VERSION
$VERSION
Packaged: $(date -u +%Y-%m-%dT%H:%M:%SZ)
Source manifest: app-hub-v11/artifacts.source.json
EOF_VERSION
echo -e "${GREEN}  ✓${NC} VERSION"

cat > "$STAGE/README.md" <<'EOF_README'
# Artifacts Collection

Manifest-built static artifact collection.

## Quick Start

```bash
./artifacts-serve
```

Then open http://localhost:8080/ . The root `index.html` is the v11 hub.

## Build Model

`app-hub-v11/artifacts.source.json` is the source of truth.

- `external-link` entries are indexed only.
- local `html-path` / `info` hrefs are copied by inferred top-level path.
- entries with `deploy.build` run their build command and copy configured `dist` output.
- `deploy.rootIndex.source` is promoted to package root `index.html`.

Generated deployment details are written to `BUILD_MANIFEST.json`.
EOF_README
echo -e "${GREEN}  ✓${NC} README.md"

OUTPUT_FILE="$OUTPUT_DIR/${PACKAGE_NAME}-${VERSION}.tar.gz"
echo ""
echo -e "${CYAN}Creating package archive...${NC}"
mkdir -p "$OUTPUT_DIR"
cd "$STAGE_ROOT"
tar -czf "$OUTPUT_FILE" "$PACKAGE_NAME"

PACKAGE_SIZE=$(du -h "$OUTPUT_FILE" | cut -f1)
echo -e "${GREEN}✓ Package created:${NC} $OUTPUT_FILE"
echo -e "${GREEN}  Size:${NC} $PACKAGE_SIZE"

echo ""
echo -e "${CYAN}Creating checksums...${NC}"
cd "$OUTPUT_DIR"
sha256sum "${PACKAGE_NAME}-${VERSION}.tar.gz" > "${PACKAGE_NAME}-${VERSION}.tar.gz.sha256"
echo -e "${GREEN}✓ Checksum:${NC} ${PACKAGE_NAME}-${VERSION}.tar.gz.sha256"

echo ""
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}Package complete!${NC}"
echo -e "${GREEN}Package:${NC} $OUTPUT_FILE"
echo -e "${GREEN}Size:${NC}   $PACKAGE_SIZE"
echo -e "${GREEN}SHA256:${NC} $(cut -d' ' -f1 "${PACKAGE_NAME}-${VERSION}.tar.gz.sha256")"
