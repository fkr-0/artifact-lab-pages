#!/usr/bin/env bash
#
# artifacts-deploy - Deploy manifest-materialized artifacts to VPS
#
# Usage:
#   ./artifacts-deploy                  # materialize + rsync stage
#   ./artifacts-deploy --dry-run        # materialize + show rsync changes only
#   ./artifacts-deploy --full           # package + upload + extract
#   ./artifacts-deploy --full --dry-run # build package, skip upload
#

set -euo pipefail

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ARTIFACTS_DIR="${ARTIFACTS_DIR:-/home/user/work/code/artifacts}"
VPS_HOST="${ARTIFACTS_VPS_HOST:-vps}"
VPS_PATH="${ARTIFACTS_VPS_PATH:-/home/user/data/artifacts}"
STAGE_DIR="$ARTIFACTS_DIR/.artifacts-deploy-stage"

FULL_MODE=0
DRY_RUN=""
for arg in "$@"; do
  case "$arg" in
    --full) FULL_MODE=1 ;;
    --dry-run) DRY_RUN="--dry-run" ;;
    *) echo -e "${RED}Unknown argument: $arg${NC}"; exit 2 ;;
  esac
done

remote_cleanup() {
  echo -e "${CYAN}Cleaning nested VCS/dependency/cache directories on VPS...${NC}"
  ssh "$VPS_HOST" "
    set -e
    find '$VPS_PATH' \
      \( -name .git -o -name node_modules -o -name .vite -o -name coverage -o -name .cache -o -name .parcel-cache -o -name .turbo -o -name .next \) \
      -prune -exec rm -rf {} +
  "
}

echo -e "${CYAN}=== Artifacts Deploy ===${NC}"
[[ -n "$DRY_RUN" ]] && echo -e "${YELLOW}  [dry-run: no files will be transferred]${NC}"
echo ""

if [[ $FULL_MODE -eq 1 ]]; then
  echo -e "${CYAN}Step 1: Building manifest package...${NC}"
  cd "$ARTIFACTS_DIR"
  PACKAGE_OUTPUT=$(./artifacts-package 2>&1)
  PACKAGE_FILE=$(echo "$PACKAGE_OUTPUT" | grep '^Package:' | awk '{print $2}')
  if [[ -z "$PACKAGE_FILE" || ! -f "$PACKAGE_FILE" ]]; then
    echo -e "${RED}ERROR: could not locate built package${NC}"
    echo "$PACKAGE_OUTPUT"
    exit 1
  fi
  PKG_SIZE=$(du -h "$PACKAGE_FILE" | cut -f1)
  echo -e "${GREEN}  Package: $PACKAGE_FILE ($PKG_SIZE)${NC}"

  if [[ -n "$DRY_RUN" ]]; then
    echo -e "${YELLOW}  [dry-run] would upload $(basename "$PACKAGE_FILE") to $VPS_HOST:$VPS_PATH${NC}"
    exit 0
  fi

  echo -e "${CYAN}Step 2: Uploading to VPS...${NC}"
  scp "$PACKAGE_FILE" "$VPS_HOST:/tmp/"
  REMOTE_ARCHIVE="/tmp/$(basename "$PACKAGE_FILE")"

  echo -e "${CYAN}Step 3: Extracting on VPS...${NC}"
  ssh "$VPS_HOST" "
    set -e
    mkdir -p '$VPS_PATH'
    cd /tmp
    tar -xzf '$REMOTE_ARCHIVE' --strip-components=1 -C '$VPS_PATH'
    rm -f '$REMOTE_ARCHIVE'
    echo 'Extracted OK'
    ls '$VPS_PATH' | head -10
  "
  remote_cleanup
  echo -e "${GREEN}Full deploy complete → $VPS_HOST:$VPS_PATH${NC}"
  exit 0
fi

echo -e "${CYAN}Materializing deploy stage from manifest...${NC}"
cd "$ARTIFACTS_DIR"
node app-hub-v11/server/artifact-build.mjs --out "$STAGE_DIR"

echo ""
echo -e "${CYAN}Syncing stage to ${VPS_HOST}:${VPS_PATH} ...${NC}"
rsync -avz --checksum --delete $DRY_RUN "$STAGE_DIR/" "$VPS_HOST:$VPS_PATH/"

if [[ -z "$DRY_RUN" ]]; then
  remote_cleanup
fi

echo ""
echo -e "${GREEN}Sync complete → https://artifacts.fkr.dev${NC}"
