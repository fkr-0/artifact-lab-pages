#!/usr/bin/env bash
#
# artifacts-deploy - Deploy artifacts to VPS
#
# Default mode: rsync (only changed files, fast incremental update)
# Full mode:    build tgz via artifacts-package, scp, extract (complete reset)
#
# Usage:
#   ./artifacts-deploy                  # rsync to default VPS target
#   ./artifacts-deploy --dry-run        # show what would change, don't transfer
#   ./artifacts-deploy --full           # full tgz package deploy (reset all files)
#   ./artifacts-deploy --full --dry-run # show package, skip upload
#

set -e

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ARTIFACTS_DIR="/home/user/work/code/artifacts"
VPS_HOST="vps"
VPS_PATH="/home/user/data/artifacts"

FULL_MODE=0
DRY_RUN=""
for arg in "$@"; do
  case "$arg" in
    --full)     FULL_MODE=1 ;;
    --dry-run)  DRY_RUN="--dry-run" ;;
  esac
done

echo -e "${CYAN}=== Artifacts Deploy ===${NC}"
[[ -n "$DRY_RUN" ]] && echo -e "${YELLOW}  [dry-run: no files will be transferred]${NC}"
echo ""

# ────────────────────────────────────────────────────────────
# FULL MODE: build tgz, upload, extract on VPS
# ────────────────────────────────────────────────────────────
if [[ $FULL_MODE -eq 1 ]]; then
  echo -e "${CYAN}Step 1: Building package...${NC}"
  cd "$ARTIFACTS_DIR"
  PACKAGE_OUTPUT=$(./artifacts-package 2>&1)
  PACKAGE_FILE=$(echo "$PACKAGE_OUTPUT" | grep "^Package:" | awk '{print $2}')
  if [[ -z "$PACKAGE_FILE" || ! -f "$PACKAGE_FILE" ]]; then
    echo -e "${RED}ERROR: could not locate built package${NC}"
    echo "$PACKAGE_OUTPUT"
    exit 1
  fi
  PKG_SIZE=$(du -h "$PACKAGE_FILE" | cut -f1)
  echo -e "${GREEN}  Package: $PACKAGE_FILE ($PKG_SIZE)${NC}"
  echo ""

  if [[ -n "$DRY_RUN" ]]; then
    echo -e "${YELLOW}  [dry-run] would upload $(basename $PACKAGE_FILE) to $VPS_HOST:$VPS_PATH${NC}"
    exit 0
  fi

  echo -e "${CYAN}Step 2: Uploading to VPS...${NC}"
  scp "$PACKAGE_FILE" "$VPS_HOST:/tmp/"
  REMOTE_ARCHIVE="/tmp/$(basename $PACKAGE_FILE)"

  echo -e "${CYAN}Step 3: Extracting on VPS...${NC}"
  ssh "$VPS_HOST" "
    set -e
    cd /tmp
    tar -xzf '$REMOTE_ARCHIVE' --strip-components=1 -C '$VPS_PATH'
    rm -f '$REMOTE_ARCHIVE'
    echo 'Extracted OK'
    ls '$VPS_PATH' | head -10
  "
  echo ""
  echo -e "${GREEN}Full deploy complete → $VPS_HOST:$VPS_PATH${NC}"
  exit 0
fi

# ────────────────────────────────────────────────────────────
# RSYNC MODE (default): incremental sync of changed files only
# ────────────────────────────────────────────────────────────
echo -e "${CYAN}Syncing to ${VPS_HOST}:${VPS_PATH} ...${NC}"
echo ""

rsync -avz --checksum $DRY_RUN \
  --include="index.html" \
  --include="ARTIFACTS_TOC.md" \
  --include="SERVER_GUIDE.md" \
  --include="SETUP_ALIASES.sh" \
  --include="artifacts-serve" \
  --include="artifacts-server.sh" \
  --include="VERSION" \
  --include="README.md" \
  --include="app-hub/" \
  --include="app-hub/**" \
  --include="spc/" \
  --include="spc/**" \
  --include="brawl/" \
  --include="brawl/ethic-brawl/" \
  --include="brawl/ethic-brawl/**" \
  --include="peernet-orca/" \
  --include="peernet-orca/**" \
  --include="peer-music-groove/" \
  --include="peer-music-groove/**" \
  --include="PeerModGroove/" \
  --include="PeerModGroove/**" \
  --include="bathroom-emergency-guide/" \
  --include="bathroom-emergency-guide/**" \
  --include="aster-relay-identity-nightline-configurable/" \
  --include="aster-relay-identity-nightline-configurable/**" \
  --exclude="*" \
  "$ARTIFACTS_DIR/" \
  "$VPS_HOST:$VPS_PATH/"

echo ""
echo -e "${GREEN}Sync complete → https://artifacts.fkr.dev${NC}"
